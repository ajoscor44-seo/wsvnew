{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/server"
    },
    {
      "source": "/vcf/:path*",
      "destination": "https://iafztzsjfpjcqbsqqxpc.supabase.co/storage/v1/object/public/vcf-files/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/admin/generate-vcf",
      "schedule": "30 20 * * *"
    }
  ]
}
